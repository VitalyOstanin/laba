{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taskstream",
  "version": "0.1.0",
  "identifier": "io.github.vitalyostanin.taskstream",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "taskstream",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5NUE0N0IxMEEzM0E2MDAKUldRQXBqTUtzVWRheVN1ZmNjRFllbEZkS1dvcGJtSE5GcklBWTFJNnZqbEEzZW9PYVRrZWIzQUMK",
      "endpoints": [
        "https://github.com/VitalyOstanin/taskstream/releases/latest/download/latest.json"
      ]
    }
  }
}
